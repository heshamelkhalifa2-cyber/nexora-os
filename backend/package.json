{
  "name": "nexora-mvp-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/invoice/fonts && cp src/invoice/fonts/*.ttf dist/invoice/fonts/",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "migrate": "for f in migrations/*.sql; do psql \"$DATABASE_URL\" -f \"$f\"; done"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "arabic-reshaper": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "pdfkit": "^0.15.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
